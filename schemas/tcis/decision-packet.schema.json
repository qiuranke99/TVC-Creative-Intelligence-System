{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tcis/schemas/decision-packet.schema.json",
  "title": "TCIS Human Decision Packet",
  "type": "object",
  "required": ["schema_version", "project_id", "packet_id", "artifact_id", "artifact_version", "stage", "interaction_phase", "decision_owner", "decision_question", "options", "recommendation", "known_facts", "assumptions", "unknowns", "hard_blocks", "allowed_responses"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "project_id": { "type": "string", "minLength": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_version": { "type": "integer", "minimum": 1 },
    "stage": { "enum": ["P0_BRIEF_ALIGNMENT", "P1_DIAGNOSIS", "P2_COMMUNICATIONS_STRATEGY", "P3_CREATIVE_BRIEF", "P4_CREATIVE_ROUTES", "P5_CORE_CREATIVE_DECISION", "P6_TVC_EXPRESSION", "P7_SCRIPT_AGENCY_BOARD", "P8_VISUAL_PREDEVELOPMENT", "P9_PRODUCTION_PITCH", "P10_DIRECTOR_TREATMENT_AWARD", "P11_PREPRODUCTION_PPM", "P12_PRODUCTION_SELECTS", "P13_OFFLINE_LOCK", "P14_FINAL_RELEASE"] },
    "interaction_phase": { "enum": ["PROPOSAL", "CONFIRMATION"] },
    "decision_owner": { "type": "string", "minLength": 1 },
    "decision_question": { "type": "string", "minLength": 1 },
    "options": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "proposition", "strengths", "risks"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "proposition": { "type": "string", "minLength": 1 },
          "strengths": { "type": "array" },
          "risks": { "type": "array" }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "required": ["option_id", "rationale"],
      "properties": {
        "option_id": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "known_facts": { "type": "array" },
    "assumptions": { "type": "array" },
    "unknowns": { "type": "array" },
    "hard_blocks": { "type": "array" },
    "allowed_responses": { "type": "array", "uniqueItems": true, "items": { "enum": ["SELECT", "ADVISE", "NONE", "REVISE", "REOPEN", "STOP", "LOCK"] }, "allOf": [{ "contains": { "const": "NONE" } }, { "contains": { "const": "REOPEN" } }] },
    "revised_artifact_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
    "prior_feedback_id": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "interaction_phase": { "const": "CONFIRMATION" } } },
      "then": { "required": ["revised_artifact_hash", "prior_feedback_id"], "properties": { "allowed_responses": { "contains": { "const": "LOCK" } } } }
    },
    {
      "if": { "properties": { "interaction_phase": { "const": "PROPOSAL" } } },
      "then": { "properties": { "allowed_responses": { "not": { "contains": { "const": "LOCK" } } } } }
    }
  ],
  "additionalProperties": true
}
