{
  "schema_version": "1.0.0",
  "scenarios": [
    {
      "id": "SYN-01-PRODUCT-DEMO-AI",
      "title": "Six-second AI-native product demonstration",
      "scope_mode": "product_demo",
      "production_mode": "ai_native",
      "start_stage": "P0_BRIEF_ALIGNMENT",
      "expected_primary_capability": "account_project_lead",
      "expected_disposition": "EXECUTE",
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["mode_classification", "brief_entry", "platform_guard"],
      "does_not_prove": ["product_claim_clearance", "creative_quality", "media_quality"]
    },
    {
      "id": "SYN-02-CAMPAIGN-SYSTEM-HYBRID",
      "title": "Hybrid multi-channel campaign system",
      "scope_mode": "campaign_system",
      "production_mode": "hybrid",
      "start_stage": "P4_CREATIVE_ROUTES",
      "expected_primary_capability": "creative_director",
      "expected_disposition": "EXECUTE",
      "platform_action": "TEST_NEW_PLATFORM",
      "proves": ["campaign_branch", "creative_ownership", "platform_applicability"],
      "does_not_prove": ["platform_quality", "client_acceptance", "campaign_effectiveness"]
    },
    {
      "id": "SYN-03-EXISTING-PLATFORM-TVC",
      "title": "New TVC expression under an existing brand platform",
      "scope_mode": "existing_platform_expression",
      "production_mode": "live_action",
      "start_stage": "P5_CORE_CREATIVE_DECISION",
      "expected_primary_capability": "creative_director",
      "expected_disposition": "EXECUTE",
      "platform_action": "INHERIT_EXISTING_PLATFORM",
      "proves": ["existing_platform_branch", "scope_control"],
      "does_not_prove": ["brand_platform_validity", "legal_clearance"]
    },
    {
      "id": "SYN-04-SOCIAL-ANIMATION",
      "title": "Native vertical social animation",
      "scope_mode": "social_native",
      "production_mode": "animation",
      "start_stage": "P6_TVC_EXPRESSION",
      "expected_primary_capability": "copywriter",
      "expected_disposition": "EXECUTE",
      "expected_conditional_capabilities": ["agency_art_director", "animation_director", "visual_development_lead", "editor"],
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["animation_exception", "social_native_requirements", "early_animatic_advice"],
      "does_not_prove": ["audience_response", "platform_delivery_acceptance"]
    },
    {
      "id": "SYN-05-BRAND-FILM-PITCH",
      "title": "Live-action brand film entering production pitch",
      "scope_mode": "brand_film",
      "production_mode": "live_action",
      "start_stage": "P9_PRODUCTION_PITCH",
      "expected_primary_capability": "agency_producer",
      "expected_disposition": "EXECUTE",
      "expected_forbidden_primary_capabilities": ["commercial_director", "production_company_producer"],
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["agency_producer_ownership", "director_award_timing"],
      "does_not_prove": ["supplier_bid", "budget_accuracy", "director_availability"]
    },
    {
      "id": "SYN-06-AI-GENERATION-SELECTS",
      "title": "AI-native generation attempts and selects",
      "scope_mode": "single_tvc",
      "production_mode": "ai_native",
      "start_stage": "P12_PRODUCTION_SELECTS",
      "expected_primary_capability": "commercial_director",
      "expected_disposition": "STOP",
      "expected_hard_block": "AI_PRODUCTION_CONTRACT_REQUIRED",
      "expected_conditional_capabilities": ["ai_generation_supervisor", "claims_rights_challenger"],
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["attempt_binding", "actual_media_gate", "generation_role_boundary"],
      "does_not_prove": ["actual_pixels_pass", "identity_continuity", "rights_clearance"]
    },
    {
      "id": "SYN-07-VERSION-SYSTEM-OFFLINE",
      "title": "Version system at offline lock",
      "scope_mode": "version_system",
      "production_mode": "hybrid",
      "start_stage": "P13_OFFLINE_LOCK",
      "expected_primary_capability": "editor",
      "expected_disposition": "STOP",
      "expected_hard_block": "AI_PRODUCTION_CONTRACT_REQUIRED",
      "expected_conditional_capabilities": ["post_producer", "media_asset_strategist", "claims_rights_challenger"],
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["editor_post_separation", "version_route"],
      "does_not_prove": ["technical_master_qc", "release_approval"]
    },
    {
      "id": "SYN-08-DIRECT-RESPONSE-STRATEGY",
      "title": "Direct-response offer at communications strategy",
      "scope_mode": "direct_response_or_offer",
      "production_mode": "vfx_first",
      "start_stage": "P2_COMMUNICATIONS_STRATEGY",
      "expected_primary_capability": "strategy_planning_lead",
      "expected_disposition": "EXECUTE",
      "expected_conditional_capabilities": ["claims_rights_challenger"],
      "expected_forbidden_primary_capabilities": ["vfx_supervisor", "director_of_photography", "editor"],
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["strategy_ownership", "technical_consultant_boundary", "claim_risk_route"],
      "does_not_prove": ["offer_legality", "conversion_lift", "production_feasibility"]
    },
    {
      "id": "SYN-09-DIRECTOR-LED-TREATMENT",
      "title": "Director-led treatment after an explicit award boundary",
      "scope_mode": "single_tvc",
      "production_mode": "director_led",
      "start_stage": "P10_DIRECTOR_TREATMENT_AWARD",
      "expected_primary_capability": "commercial_director",
      "expected_disposition": "STOP",
      "expected_hard_block": "DIRECTOR_LED_EXCEPTION_REQUIRED",
      "expected_conditional_capabilities": ["production_company_producer"],
      "expected_forbidden_primary_capabilities": ["director_of_photography", "production_designer"],
      "platform_action": "REJECT_NEW_PLATFORM",
      "proves": ["director_led_exception", "treatment_ownership", "craft_advice_boundary"],
      "does_not_prove": ["director_award", "treatment_quality", "bid_feasibility"]
    }
  ]
}
